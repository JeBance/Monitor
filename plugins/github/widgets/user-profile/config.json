{
  "type": "text",
  "title": "GitHub: {{username}}",
  "updateInterval": 600,
  "settingsSchema": {
    "type": "object",
    "properties": {
      "username": {
        "type": "string",
        "default": "torvalds",
        "description": "GitHub username"
      }
    }
  },
  "dataSource": {
    "url": "https://api.github.com/users/{{username}}",
    "method": "GET",
    "transform": {
      "type": "pick",
      "fields": ["name", "public_repos", "followers", "following", "avatar_url", "bio", "company", "location"]
    }
  },
  "template": {
    "html": "<div style='display: flex; gap: 16px; align-items: flex-start;'><img src='{{avatar_url}}' alt='Avatar' style='width: 80px; height: 80px; border-radius: 50%;' /><div style='flex: 1;'><div style='font-size: 1.25em; font-weight: bold;'>{{name}}</div><div style='color: #888; font-size: 0.9em; margin: 4px 0;'>{{bio}}</div><div style='display: flex; gap: 16px; margin-top: 12px;'><div><span style='font-weight: bold; color: #fbbf24;'>{{public_repos}}</span> <span style='color: #666;'>repos</span></div><div><span style='font-weight: bold; color: #60a5fa;'>{{followers}}</span> <span style='color: #666;'>followers</span></div><div><span style='font-weight: bold; color: #34d399;'>{{following}}</span> <span style='color: #666;'>following</span></div></div></div></div>",
    "sanitize": true
  },
  "styles": {
    "backgroundColor": "#1e1e2e",
    "borderRadius": "12px"
  }
}
