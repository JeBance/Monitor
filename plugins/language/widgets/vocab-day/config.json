{
  "type": "text",
  "title": "Word of the Day",
  "updateInterval": 86400,
  "settingsSchema": {
    "type": "object",
    "properties": {
      "language": {
        "type": "string",
        "enum": ["es", "fr", "de", "it", "pt", "ja", "zh", "ko", "ru"],
        "default": "es",
        "description": "Target language"
      }
    }
  },
  "dataSource": {
    "url": "https://api.dictionaryapi.dev/api/v2/entries/{{language}}/random",
    "method": "GET",
    "transform": {
      "type": "format",
      "format": "sync"
    }
  },
  "template": {
    "html": "<div style='text-align: center; padding: 12px;'><div style='font-size: 2.5em; margin-bottom: 8px;'>📚</div><div style='font-size: 1.8em; font-weight: bold; color: #60a5fa;'>{{word}}</div><div style='color: #888; font-size: 0.9em; margin: 4px 0;'>/{{pronunciation}}/</div><div style='font-style: italic; color: #e0e0e0; margin-top: 12px;'>{{definition}}</div><div style='margin-top: 12px; padding: 8px; background: #252540; border-radius: 6px;'><span style='color: #aaa;'>Example:</span> <span style='color: #fbbf24;'>{{example}}</span></div></div>",
    "sanitize": true
  },
  "styles": {
    "backgroundColor": "#1e1e2e",
    "borderRadius": "12px"
  }
}
