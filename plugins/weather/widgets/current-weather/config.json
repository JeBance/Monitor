{
  "type": "text",
  "title": "Weather in {{city}}",
  "updateInterval": 1800,
  "settingsSchema": {
    "type": "object",
    "properties": {
      "city": {
        "type": "string",
        "default": "Moscow",
        "description": "City name"
      },
      "latitude": {
        "type": "number",
        "default": 55.7558,
        "description": "City latitude"
      },
      "longitude": {
        "type": "number",
        "default": 37.6173,
        "description": "City longitude"
      }
    }
  },
  "dataSource": {
    "url": "https://api.open-meteo.com/v1/forecast?latitude={{latitude}}&longitude={{longitude}}&current_weather=true",
    "method": "GET",
    "transform": {
      "type": "pick",
      "fields": ["temperature", "windspeed", "winddirection", "weathercode"]
    }
  },
  "template": {
    "html": "<div style='font-size: 3em; font-weight: bold;'>{{temperature}}°C</div><div style='color: #aaa; margin-top: 8px;'>Wind: {{windspeed}} km/h {{winddirection}}°</div><div style='color: #888; margin-top: 4px;'>WMO code: {{weathercode}}</div>",
    "sanitize": true
  },
  "styles": {
    "backgroundColor": "#1e1e2e",
    "borderRadius": "12px"
  }
}
