{
  "type": "indicator",
  "title": "Gold Price",
  "updateInterval": 300,
  "settingsSchema": {
    "type": "object",
    "properties": {
      "currency": {
        "type": "string",
        "default": "USD",
        "enum": ["USD", "EUR", "GBP", "JPY"],
        "description": "Price currency"
      },
      "metal": {
        "type": "string",
        "default": "XAU",
        "enum": ["XAU", "XAG", "XPT", "XPD"],
        "description": "Precious metal (Gold/Silver/Platinum/Palladium)"
      }
    }
  },
  "dataSource": {
    "url": "https://api.exchangerate-api.com/v4/latest/{{currency}}",
    "method": "GET",
    "transform": {
      "type": "format",
      "format": "sync"
    }
  },
  "template": {
    "html": "<div style='text-align: center;'><div style='font-size: 3em;'>{{#if eq metal \"XAU\"}}🥇{{else if eq metal \"XAG\"}}🥈{{else if eq metal \"XPT\"}}⚪{{else}}🔘{{/if}}</div><div style='font-size: 2em; font-weight: bold; color: #fbbf24; margin-top: 8px;'>${{price}}</div><div style='color: #888; margin-top: 8px;'>per troy oz</div><div style='margin-top: 12px; padding: 8px; background: #252540; border-radius: 6px; font-size: 0.85em;'><span style='color: #aaa;'>{{metal}}/{{currency}}</span></div></div>",
    "sanitize": true
  },
  "styles": {
    "backgroundColor": "#1e1e2e",
    "borderRadius": "12px"
  }
}
