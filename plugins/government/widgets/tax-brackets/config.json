    }
  },
  "template": {
    "html": "<table><thead><tr><th>Rate</th><th>Single</th><th>Married</th></tr></thead><tbody><tr><td style='color: #22c55e;'>10%</td><td>$0 – $11,000</td><td>$0 – $22,000</td></tr><tr><td style='color: #60a5fa;'>12%</td><td>$11,001 – $44,725</td><td>$22,001 – $89,450</td></tr><tr><td style='color: #fbbf24;'>22%</td><td>$44,726 – $95,375</td><td>$89,451 – $190,750</td></tr><tr><td style='color: #f97316;'>24%</td><td>$95,376 – $182,100</td><td>$190,751 – $364,200</td></tr><tr><td style='color: #ef4444;'>32%</td><td>$182,101 – $231,250</td><td>$364,201 – $462,500</td></tr><tr><td style='color: #a855f7;'>35%</td><td>$231,251 – $578,125</td><td>$462,501 – $693,750</td></tr><tr><td style='color: #dc2626;'>37%</td><td>$578,126+</td><td>$693,751+</td></tr></tbody></table><div style='margin-top: 12px; font-size: 0.75em; color: #666;'>Source: IRS 2024</div>",
