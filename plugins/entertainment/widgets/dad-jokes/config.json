{
  "type": "text",
  "title": "Dad Joke",
  "updateInterval": 0,
  "settingsSchema": {
    "type": "object",
    "properties": {}
  },
  "dataSource": {
    "url": "https://icanhazdadjoke.com/",
    "method": "GET",
    "headers": {
      "Accept": "application/json"
    },
    "transform": {
      "type": "pick",
      "fields": ["joke"]
    }
  },
  "template": {
    "html": "<div style='text-align: center; padding: 16px;'><div style='font-size: 1.2em; line-height: 1.6; color: #e0e0e0;'>{{joke}}</div><div style='margin-top: 16px; color: #888; font-size: 0.9em;'>😄 Want another? Refresh the widget!</div></div>",
    "sanitize": true
  },
  "styles": {
    "backgroundColor": "#1e1e2e",
    "borderRadius": "12px"
  }
}
