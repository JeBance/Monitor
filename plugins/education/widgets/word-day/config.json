{
  "type": "text",
  "title": "Word of the Day",
  "updateInterval": 86400,
  "settingsSchema": {
    "type": "object",
    "properties": {
      "language": {
        "type": "string",
        "enum": ["en", "es", "fr", "de", "it"],
        "default": "en",
        "description": "Dictionary language"
      }
    }
  },
  "dataSource": {
    "url": "https://api.dictionaryapi.dev/api/v2/entries/en/random",
    "method": "GET",
    "transform": {
      "type": "jsonpath",
      "expression": "$[0]"
    }
  },
  "template": {
    "html": "<div style='text-align: center; padding: 12px;'><div style='font-size: 2em; font-weight: bold; color: #60a5fa;'>{{word}}</div><div style='color: #888; font-size: 0.9em; margin: 4px 0;'>{{phonetic}}</div><div style='margin-top: 12px; font-style: italic; color: #e0e0e0;'>{{meanings.0.definitions.0.definition}}</div><div style='margin-top: 8px; color: #888; font-size: 0.85em;'>Example: {{meanings.0.definitions.0.example}}</div></div>",
    "sanitize": true
  },
  "styles": {
    "backgroundColor": "#1e1e2e",
    "borderRadius": "12px"
  }
}
