{
  "type": "text",
  "title": "{{package}} Version",
  "updateInterval": 3600,
  "settingsSchema": {
    "type": "object",
    "properties": {
      "package": {
        "type": "string",
        "default": "typescript",
        "description": "NPM package name"
      }
    }
  },
  "dataSource": {
    "url": "https://registry.npmjs.org/{{package}}/latest",
    "method": "GET",
    "transform": {
      "type": "pick",
      "fields": ["version", "name", "description"]
    }
  },
  "template": {
    "html": "<div style='text-align: center;'><div style='font-size: 2.5em; font-weight: bold; color: #22c55e;'>v{{version}}</div><div style='color: #888; margin-top: 8px; font-size: 0.9em;'>{{description}}</div><a href='https://www.npmjs.com/package/{{package}}' target='_blank' style='display: inline-block; margin-top: 12px; padding: 6px 12px; background: #cb3837; color: white; text-decoration: none; border-radius: 4px; font-size: 0.85em;'>View on NPM</a></div>",
    "sanitize": true
  },
  "styles": {
    "backgroundColor": "#1e1e2e",
    "borderRadius": "12px"
  }
}
