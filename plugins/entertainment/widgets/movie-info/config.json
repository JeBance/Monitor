{
  "type": "text",
  "title": "Movie: {{movie}}",
  "updateInterval": 0,
  "settingsSchema": {
    "type": "object",
    "properties": {
      "movie": {
        "type": "string",
        "default": "The Matrix",
        "description": "Movie title to search"
      }
    }
  },
  "dataSource": {
    "url": "https://www.omdbapi.com/?t={{movie}}&apikey={{apiKey}}",
    "method": "GET",
    "transform": {
      "type": "pick",
      "fields": ["Title", "Year", "Rated", "Released", "Runtime", "Genre", "Director", "Actors", "Plot", "imdbRating", "Poster"]
    }
  },
  "template": {
    "html": "<div style='display: flex; gap: 16px; align-items: flex-start;'><img src='{{Poster}}' alt='Poster' style='width: 120px; border-radius: 8px;' onerror='this.style.display=\"none\"' /><div style='flex: 1;'><div style='font-size: 1.3em; font-weight: bold;'>{{Title}} ({{Year}})</div><div style='color: #888; margin: 4px 0;'>{{Genre}}</div><div style='margin: 8px 0;'><span style='background: #fbbf24; color: #000; padding: 2px 8px; border-radius: 4px; font-weight: bold;'>★ {{imdbRating}}</span></div><div style='font-size: 0.9em; color: #aaa; line-height: 1.5;'>{{Plot}}</div><div style='margin-top: 8px; font-size: 0.85em; color: #888;'>Director: {{Director}}</div></div></div>",
    "sanitize": true
  },
  "styles": {
    "backgroundColor": "#1e1e2e",
    "borderRadius": "12px"
  }
}
