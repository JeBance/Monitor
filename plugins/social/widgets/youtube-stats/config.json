{
  "type": "text",
  "title": "YouTube: {{channelId}}",
  "updateInterval": 3600,
  "settingsSchema": {
    "type": "object",
    "properties": {
      "channelId": {
        "type": "string",
        "default": "UC9-y-6csu5WGm29I7JiwpnA",
        "description": "YouTube Channel ID"
      }
    }
  },
  "dataSource": {
    "url": "https://www.googleapis.com/youtube/v3/channels?part=statistics,snippet&id={{channelId}}&key={{apiKey}}",
    "method": "GET",
    "transform": {
      "type": "jsonpath",
      "expression": "$.items[0]"
    }
  },
  "template": {
    "html": "<div style='text-align: center;'><img src='{{snippet.thumbnails.medium.url}}' alt='Channel' style='width: 80px; height: 80px; border-radius: 50%; margin-bottom: 12px;' /><div style='font-size: 1.2em; font-weight: bold;'>{{snippet.title}}</div><div style='font-size: 2em; font-weight: bold; color: #ff0000; margin-top: 12px;'>{{statistics.subscriberCount}}</div><div style='color: #888; margin-top: 4px;'>subscribers</div><div style='display: flex; justify-content: center; gap: 16px; margin-top: 12px;'><div><span style='color: #aaa;'>Videos:</span> {{statistics.videoCount}}</div><div><span style='color: #aaa;'>Views:</span> {{statistics.viewCount}}</div></div></div>",
    "sanitize": true
  },
  "styles": {
    "backgroundColor": "#1e1e2e",
    "borderRadius": "12px"
  }
}
