{
  "type": "text",
  "title": "IP Lookup",
  "updateInterval": 0,
  "settingsSchema": {
    "type": "object",
    "properties": {
      "ipAddress": {
        "type": "string",
        "default": "8.8.8.8",
        "description": "IP address to lookup"
      }
    }
  },
  "dataSource": {
    "url": "https://ipapi.co/{{ipAddress}}/json/",
    "method": "GET",
    "transform": {
      "type": "pick",
      "fields": ["ip", "city", "region", "country_name", "org", "timezone", "latitude", "longitude", "postal"]
    }
  },
  "template": {
    "html": "<div style='text-align: center;'><div style='font-size: 1.8em; font-weight: bold; color: #fbbf24;'>{{ip}}</div><div style='margin-top: 12px;'><div style='font-size: 1.3em; color: #aaa;'>{{city}}, {{region}}</div><div style='color: #888;'>{{country_name}} {{postal}}</div></div><div style='margin-top: 12px; padding: 10px; background: #252540; border-radius: 6px; font-size: 0.85em; color: #888; text-align: left;'><div style='margin-bottom: 4px;'>ISP: {{org}}</div><div style='margin-bottom: 4px;'>Timezone: {{timezone}}</div><div>Coordinates: {{latitude}}, {{longitude}}</div></div></div>",
    "sanitize": true
  },
  "styles": {
    "backgroundColor": "#1e1e2e",
    "borderRadius": "12px"
  }
}
