{
  "type": "indicator",
  "title": "NPM: {{package}}",
  "updateInterval": 3600,
  "settingsSchema": {
    "type": "object",
    "properties": {
      "package": {
        "type": "string",
        "default": "react",
        "description": "NPM package name"
      }
    }
  },
  "dataSource": {
    "url": "https://api.npmjs.org/downloads/point/last-month/{{package}}",
    "method": "GET",
    "transform": {
      "type": "pick",
      "fields": ["downloads", "package", "start", "end"]
    }
  },
  "template": {
    "html": "<div style='text-align: center;'><div style='font-size: 2.5em; font-weight: bold; color: #cb3837;'>{{downloads}}</div><div style='color: #888; margin-top: 8px;'>downloads / month</div><div style='margin-top: 12px; padding: 8px; background: #252540; border-radius: 6px; font-size: 0.85em; color: #aaa;'>{{package}}</div></div>",
    "sanitize": true
  },
  "styles": {
    "backgroundColor": "#1e1e2e",
    "borderRadius": "12px"
  }
}
