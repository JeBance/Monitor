{
  "type": "text",
  "title": "Sun Times",
  "updateInterval": 3600,
  "settingsSchema": {
    "type": "object",
    "properties": {
      "latitude": {
        "type": "number",
        "default": 55.7558,
        "description": "Location latitude"
      },
      "longitude": {
        "type": "number",
        "default": 37.6173,
        "description": "Location longitude"
      }
    }
  },
  "dataSource": {
    "url": "https://api.open-meteo.com/v1/forecast?latitude={{latitude}}&longitude={{longitude}}&daily=sunrise,sunset&timezone=auto&forecast_days=1",
    "method": "GET",
    "transform": {
      "type": "pick",
      "fields": ["daily"]
    }
  },
  "template": {
    "html": "<div style='display: flex; justify-content: space-around; align-items: center; text-align: center;'><div><div style='font-size: 2.5em; color: #fbbf24;'>🌅</div><div style='font-size: 1.5em; font-weight: bold; margin-top: 8px;'>{{daily.sunrise.0}}</div><div style='color: #888; margin-top: 4px;'>Sunrise</div></div><div style='width: 1px; background: #333; height: 80px;'></div><div><div style='font-size: 2.5em; color: #f97316;'>🌇</div><div style='font-size: 1.5em; font-weight: bold; margin-top: 8px;'>{{daily.sunset.0}}</div><div style='color: #888; margin-top: 4px;'>Sunset</div></div></div>",
    "sanitize": true
  },
  "styles": {
    "backgroundColor": "#1e1e2e",
    "borderRadius": "12px"
  }
}
