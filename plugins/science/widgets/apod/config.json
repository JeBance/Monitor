{
  "type": "text",
  "title": "Astronomy Picture of the Day",
  "updateInterval": 86400,
  "settingsSchema": {
    "type": "object",
    "properties": {
      "apiKey": {
        "type": "string",
        "default": "DEMO_KEY",
        "description": "NASA API key (get at api.nasa.gov)"
      }
    }
  },
  "dataSource": {
    "url": "https://api.nasa.gov/planetary/apod?api_key={{apiKey}}",
    "method": "GET",
    "transform": {
      "type": "pick",
      "fields": ["title", "explanation", "url", "hdurl", "media_type"]
    }
  },
  "template": {
    "html": "<div style='text-align: center;'><div style='font-size: 1.1em; font-weight: bold; margin-bottom: 12px; color: #e0e0e0;'>{{title}}</div>{{#if eq media_type \"image\"}}<img src='{{url}}' alt='APOD' style='width: 100%; max-height: 200px; object-fit: cover; border-radius: 8px; margin-bottom: 12px;' />{{/if}}<div style='font-size: 0.9em; color: #aaa; line-height: 1.5; text-align: left;'>{{explanation}}</div><a href='https://apod.nasa.gov' target='_blank' style='display: inline-block; margin-top: 12px; color: #60a5fa; font-size: 0.85em;'>View on NASA APOD →</a></div>",
    "sanitize": true
  },
  "styles": {
    "backgroundColor": "#1e1e2e",
    "borderRadius": "12px"
  }
}
